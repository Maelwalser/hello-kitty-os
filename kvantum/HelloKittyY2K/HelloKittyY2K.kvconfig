min_height=+8

[HeaderSection]
frame=true
frame.element=header
frame.top=2
frame.bottom=2
frame.left=2
frame.right=2
interior=true
interior.element=header
text.normal.color=#4A2040
text.focus.color=#FF69B4
text.press.color=#FF69B4
text.toggle.color=#FF69B4
text.shadow=0

[SizeGrip]
frame=false
interior=true
interior.element=sizegrip
indicator.element=resize-grip
indicator.size=16

[Toolbar]
frame=true
frame.element=toolbar
frame.top=0
frame.bottom=3
frame.left=0
frame.right=0
interior=true
interior.element=toolbar
text.normal.color=#4A2040

[Scrollbar]
frame=false
interior=true
interior.element=scrollbar
indicator.element=arrow
indicator.size=10

[ScrollbarGroove]
frame=true
frame.element=scrollbargroove
frame.top=1
frame.bottom=1
frame.left=1
frame.right=1
interior=true
interior.element=scrollbargroove

[ScrollbarSlider]
frame=true
frame.element=scrollbar
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4
interior=true
interior.element=scrollbar
indicator.element=grip
indicator.size=8
min_height=+24

[Progressbar]
