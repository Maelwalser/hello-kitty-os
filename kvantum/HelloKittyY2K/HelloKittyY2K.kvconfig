frame.element=tooltip
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4
interior=true
interior.element=tooltip
text.normal.color=#4A2040
text.shadow=0

[GroupBox]
frame=true
frame.element=group
frame.top=4
frame.bottom=4
frame.left=4
frame.right=4
interior=true
interior.element=group
text.normal.color=#4A2040
text.focus.color=#FF69B4
text.shadow=0
text.margin=true
text.margin.top=2
text.margin.bottom=2
text.margin.left=2
text.margin.right=2

[TabFrame]
frame=true
frame.element=tabframe
frame.top=3
frame.bottom=3
frame.left=3
frame.right=3
interior=true
interior.element=tabframe

[TabBarTab]
frame=true
frame.element=tab
frame.top=3
frame.bottom=3
frame.left=6
frame.right=6
interior=true
interior.element=tab
text.normal.color=#4A2040
text.focus.color=#FF69B4
text.press.color=#FFFFFF
text.toggle.color=#4A2040
text.shadow=0
text.margin=true
text.margin.top=2
text.margin.bottom=2
text.margin.left=4
text.margin.right=4
indicator.element=tab
indicator.size=12
