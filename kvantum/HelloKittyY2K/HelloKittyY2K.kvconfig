frame.bottom=2
frame.left=2
frame.right=2
interior=true
interior.element=progress
text.normal.color=#4A2040
text.focus.color=#FFFFFF
text.press.color=#FFFFFF
text.bold=true

[ProgressbarContents]
frame=true
frame.element=progress-pattern
frame.top=2
frame.bottom=2
frame.left=2
frame.right=2
interior=true
interior.element=progress-pattern

[Slider]
frame=false
interior=true
interior.element=slider
frame.element=slider
frame.top=3
frame.bottom=3
frame.left=3
frame.right=3

[SliderCursor]
frame=false
interior=true
interior.element=sliderhandle
indicator.element=handle
indicator.size=18

[Dock]
frame=true
frame.element=dock
frame.top=1
frame.bottom=1
frame.left=1
frame.right=1
interior=true
interior.element=dock

[DockTitle]
frame=false
interior=true
interior.element=dock
text.normal.color=#4A2040
text.focus.color=#FF69B4
text.bold=true

[Splitter]
frame=false
interior=true
interior.element=splitter
indicator.element=splitter

[Window]
frame=false
interior=true
interior.element=window
